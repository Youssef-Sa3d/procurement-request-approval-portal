<mvc:View
    controllerName="procurement.ui.controller.RequestDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="idRequestDetailPage"
        showNavButton="true"
        navButtonPress=".onNavBack">

        <headerContent>
            <ObjectStatus
                id="idHeaderStatus"
                text="{
                    path: 'status',
                    formatter: '.formatter.formatStatusText'
                }"
                state="{
                    path: 'status',
                    formatter: '.formatter.formatStatus'
                }"
                inverted="true"/>
        </headerContent>

        <content>
            <f:SimpleForm
                id="idRequestDetailForm"
                editable="false"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="4"
                labelSpanS="12"
                columnsXL="2"
                columnsL="2"
                columnsM="1">

                <f:content>
                    <Label id="idLabelNumber"   text="Request #"/>
                    <Text  id="idTextNumber"    text="{requestNumber}"/>

                    <Label id="idLabelTitle"    text="{i18n>label.title}"/>
                    <Text  id="idTextTitle"     text="{title}"/>

                    <Label id="idLabelDept"     text="{i18n>label.department}"/>
                    <Text  id="idTextDept"      text="{department/name}"/>

                    <Label id="idLabelVendor"   text="{i18n>label.vendor}"/>
                    <Text  id="idTextVendor"    text="{vendor/name}"/>

                    <Label id="idLabelSubmitted" text="Submitted"/>
                    <Text  id="idTextSubmitted"
                        text="{
                            path: 'submittedAt',
                            formatter: '.formatter.formatDate'
                        }"/>

                    <Label id="idLabelJustification" text="{i18n>label.justification}"/>
                    <Text  id="idTextJustification"  text="{justification}" wrapping="true"/>
                </f:content>
            </f:SimpleForm>

            <Panel
                id="idItemsPanel"
                headerText="{i18n>label.items}"
                expandable="false">

                <Table id="idItemsTable" items="{items}">
                    <columns>
                        <Column id="idColDesc"  width="auto">
                            <Text text="{i18n>createRequest.col.description}"/>
                        </Column>
                        <Column id="idColQty"   width="6rem" hAlign="End">
                            <Text text="{i18n>createRequest.col.qty}"/>
                        </Column>
                        <Column id="idColPrice" width="9rem" hAlign="End">
                            <Text text="{i18n>createRequest.col.unitPrice}"/>
                        </Column>
                        <Column id="idColAmount" width="9rem" hAlign="End">
                            <header>
                                <Text text="{i18n>createRequest.col.amount}"/>
                            </header>
                            <footer>
                                <ObjectNumber
                                    id="idTotalAmount"
                                    number="{totalAmount}"
                                    unit="{currency}"
                                    emphasized="true"/>
                            </footer>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem id="idItemRow">
                            <cells>
                                <Text id="idCellDesc"  text="{description}"/>
                                <Text id="idCellQty"   text="{quantity}"/>
                                <ObjectNumber id="idCellPrice"  number="{unitPrice}"/>
                                <ObjectNumber id="idCellAmount" number="{amount}" emphasized="true"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>

            <Panel
                id="idTimelinePanel"
                headerText="Approval Timeline"
                expandable="false">

                <List
                    id="idApprovalList"
                    items="{approvalChain}"
                    noDataText="No approval history yet.">
                    <CustomListItem id="idApprovalItem">
                        <HBox id="idApprovalHBox" alignItems="Center" class="sapUiSmallMargin">
                            <core:Icon
                                id="idApprovalIcon"
                                src="{
                                    path: 'action',
                                    formatter: '.formatter.formatApprovalIcon'
                                }"
                                color="{
                                    path: 'action',
                                    formatter: '.formatter.formatApprovalState'
                                }"
                                size="1.5rem"
                                class="sapUiSmallMarginEnd"/>
                            <VBox id="idApprovalVBox">
                                <Title id="idApprovalStage" text="{stage}" level="H6"/>
                                <Text  id="idApprovalAction"   text="{action}"/>
                                <Text  id="idApprovalComments" text="{comments}" wrapping="true"/>
                                <Text  id="idApprovalDate"
                                    text="{
                                        path: 'actionAt',
                                        formatter: '.formatter.formatDate'
                                    }"/>
                            </VBox>
                        </HBox>
                    </CustomListItem>
                </List>
            </Panel>
        </content>

        <footer>
            <Toolbar id="idFooterToolbar">
                <ToolbarSpacer/>
                <Button
                    id="idSubmitBtn"
                    text="{i18n>btn.submit}"
                    type="Emphasized"
                    press=".onSubmit"
                    visible="{local>/canSubmit}"/>
            </Toolbar>
        </footer>
    </Page>

</mvc:View>
